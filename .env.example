PROJECT_NAME="Pivot Backend Build Team"
STACK_NAME=pivot-backend-build-team
SWARM_MANAGER_HOST=pivotcompute.store
SWARM_MANAGER_PORT=2377
SWARM_MANAGER_LOCAL_MODE=false
SWARM_ADAPTER_BASE_URL=http://swarm-adapter:8010
SWARM_ADAPTER_TOKEN=replace-with-internal-adapter-token
OPENAI_API_KEY=replace-with-project-local-key
CODEX_AUTH_JSON_PATH=backend/.codex/auth.json
CODEX_MODEL_PROVIDER=fox
# Supported values: gpt-5, gpt-5-codex
CODEX_MODEL=gpt-5
CODEX_REVIEW_MODEL=gpt-5
# Supported values: high, medium, low, minimal
CODEX_MODEL_REASONING_EFFORT=high
CODEX_DISABLE_RESPONSE_STORAGE=true
CODEX_NETWORK_ACCESS=enabled
CODEX_WINDOWS_WSL_SETUP_ACKNOWLEDGED=true
CODEX_MODEL_CONTEXT_WINDOW=1000000
CODEX_MODEL_AUTO_COMPACT_TOKEN_LIMIT=900000
CODEX_PROVIDER_NAME=fox
CODEX_PROVIDER_BASE_URL=https://code.newcli.com/codex/v1
CODEX_PROVIDER_WIRE_API=responses
CODEX_PROVIDER_REQUIRES_OPENAI_AUTH=true
WIREGUARD_ENABLED=true
WIREGUARD_INTERFACE=wg-seller
WIREGUARD_ENDPOINT_HOST=pivotcompute.store
WIREGUARD_ENDPOINT_PORT=45182
WIREGUARD_SERVER_PUBLIC_KEY=puGAoUTF0vyha+32vxQ+BBVOWXlCOUzhFoNe5tJ9hyo=
WIREGUARD_ALLOWED_IPS=10.66.66.0/24
WIREGUARD_NETWORK_CIDR=10.66.66.0/24
WIREGUARD_DNS=
WIREGUARD_PERSISTENT_KEEPALIVE=25
WIREGUARD_SERVER_INTERFACE=wg0
WIREGUARD_SERVER_CONFIG_PATH=/etc/wireguard/wg0.conf
WIREGUARD_SERVER_LOCAL_MODE=false
WIREGUARD_SERVER_SSH_ENABLED=false
WIREGUARD_SERVER_SSH_HOST=pivotcompute.store
WIREGUARD_SERVER_SSH_PORT=22
WIREGUARD_SERVER_SSH_USER=root
WIREGUARD_SERVER_SSH_PASSWORD=
WIREGUARD_SERVER_SSH_KEY_PATH=
BACKEND_HOST_PORT=8000
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=16379
REGISTRY_HOST_PORT=5000
PORTAINER_HTTPS_PORT=9443
PORTAINER_STACK_NAME=portainer
# Remote seller / buyer pushes should use the public HTTPS registry entry on 443.
# Docker image refs should still be written as pivotcompute.store/<repo>:<tag> without https:// or :443.
REGISTRY_HOST=pivotcompute.store
REGISTRY_BIND_IP=0.0.0.0
BACKEND_SWARM_IMAGE=${REGISTRY_HOST}/pivot-backend-build-team/backend:swarm-local
BENCHMARK_STACK_NAME=pivot-benchmark
BENCHMARK_SWARM_IMAGE=${REGISTRY_HOST}/pivot-backend-build-team/benchmark-worker:swarm-local
BENCHMARK_JOB_ID=bench-local-001
BENCHMARK_LISTING_ID=listing-local-001
BENCHMARK_REQUESTED_PROFILE=cpu-small
BENCHMARK_KEEPALIVE_SECONDS=1800
BENCHMARK_TARGET_COMPUTE_NODE_ID=compute-local-001
PORTAINER_AGENT_IMAGE=${REGISTRY_HOST}/portainer/agent:lts
PORTAINER_SERVER_IMAGE=${REGISTRY_HOST}/portainer/portainer-ce:lts
LOCAL_SELLER_NODE_NAME=seller-local-001
LOCAL_SELLER_CONTAINER_NAME=pivot-local-seller-node
LOCAL_SELLER_DOCKER_VOLUME=pivot-local-seller-node-data
LOCAL_SELLER_NODE_CPUS=1.0
LOCAL_SELLER_NODE_MEMORY=1024m
LOCAL_SELLER_DOCKER_IMAGE=docker:26.1-dind
LOCAL_SELLER_COMPUTE_NODE_ID=compute-local-001
LOCAL_SELLER_USER_ID=seller-local-001
LOCAL_SELLER_ACCELERATOR=cpu
ENVIRONMENT=local
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173"
SECRET_KEY=local-dev-secret-key-change-me
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=local-admin-password
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=pivot_backend
POSTGRES_USER=postgres
POSTGRES_PASSWORD=local-postgres-password
DATABASE_URL=
FRONTEND_HOST=http://localhost:5173
SENTRY_DSN=
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=false
